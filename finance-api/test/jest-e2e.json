{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "projects": [
    {
      "displayName": "unit",
      "testEnvironment": "node",
      "testMatch": ["<rootDir>/tests/unit/**/*.spec.ts"]
    },
    {
      "displayName": "e2e",
      "testEnvironment": "node",
      "testMatch": ["<rootDir>/tests/e2e/**/*.e2e-spec.ts"]
    }
  ]
}
